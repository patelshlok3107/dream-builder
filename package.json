{
    "name": "vex-dream-builder",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "description": "VEX — AI Startup Operating System",
    "scripts": {
        "dev": "concurrently -k -n SERVER,WEB -c yellow,cyan \"npm run server\" \"npm run web\"",
        "web": "vite",
        "server": "node --watch server/index.js",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "tsc --noEmit",
        "db:setup": "node server/db/setup.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "lucide-react": "^0.441.0",
        "pg": "^8.12.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.26.2"
    },
    "devDependencies": {
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.0.1",
        "postcss": "^8.4.45",
        "tailwindcss": "^3.4.10",
        "typescript": "^5.5.4",
        "vite": "^5.4.3"
    }
}
